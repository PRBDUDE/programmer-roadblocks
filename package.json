{
  "name": "programmer-roadblocks",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:loc:dev": "concurrently \"npm run loc:data:dev\" \"npm run loc:dev\"",
    "start:dev": "ng serve --configuration dev",
    "start:sit": "ng serve --configuration sit",
    "start:stg": "ng serve --configuration stg",
    "start:prd": "ng serve --configuration prd",
    "loc:data:dev": "json-server --watch data/db.json",
    "loc:dev": "ng serve --configuration loc-dev --proxy-config proxy.conf.json",
    "build": "ng build",
    "build:dev": "ng build --configuration dev",
    "build:sit": "ng build --configuration sit",
    "build:qat": "ng build --configuration qat",
    "build:stg": "ng build --configuration stg",
    "build:prd": "ng build --configuration prd",
    "watch": "ng build --watch --configuration dev",
    "test": "ng test",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.10.0",
  "dependencies": {
    "@adobe/css-tools": "^4.4.4",
    "@angular/animations": "^21.2.10",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/platform-browser": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "^4.5.1",
    "font-awesome": "^4.7.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.10",
    "concurrently": "^9.2.1",
    "angular-eslint": "21.2.0",
    "eslint": "^10.2.1",
    "jsdom": "^28.1.0",
    "json-server": "^0.17.4",
    "typescript-eslint": "8.56.0",
    "vitest": "^4.1.5",
    "typescript": "^5.9.3"
  }
}
